'
-- 1. Skapa baskategorier och oberoende tabeller
CREATE TABLE IF NOT EXISTS rooms (
    room_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS areas (
    area_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS problem_category (
    problem_category_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS ingredients (
    ingredient_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS units (
    unit_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS tools (
    tool_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS blog_category (
    blog_category_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL
);

-- 2. Skapa huvudtabeller (Recipes och Blog Posts)
CREATE TABLE IF NOT EXISTS recipes (
    recipe_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    title TEXT NOT NULL,
    description TEXT,
    image TEXT, -- URL till Supabase Storage
    difficulty TEXT,
    time_minutes INTEGER,
    eco_friendly BOOLEAN DEFAULT false,
    slug TEXT UNIQUE NOT NULL,
    created_at TIMESTAMPTZ DEFAULT now()
);

CREATE TABLE IF NOT EXISTS blog_posts (
    blog_post_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    title TEXT NOT NULL,
    content TEXT NOT NULL,
    image TEXT,
    slug TEXT UNIQUE NOT NULL,
    published_at TIMESTAMPTZ DEFAULT now()
);

-- 3. Skapa tabeller med Foreign Keys (Relationer)
CREATE TABLE IF NOT EXISTS problems (
    problem_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL,
    problem_category_id BIGINT REFERENCES problem_category(problem_category_id) ON DELETE CASCADE NOT NULL
);

CREATE TABLE IF NOT EXISTS recipe_steps (
    recipe_step_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    recipe_id BIGINT REFERENCES recipes(recipe_id) ON DELETE CASCADE NOT NULL,
    instruction TEXT NOT NULL,
    step_order INTEGER NOT NULL
);

-- 4. Kopplingstabeller (Många-till-många relationer)
CREATE TABLE IF NOT EXISTS room_area (
    room_area_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    room_id BIGINT REFERENCES rooms(room_id) ON DELETE CASCADE NOT NULL,
    area_id BIGINT REFERENCES areas(area_id) ON DELETE CASCADE NOT NULL,
    UNIQUE(room_id, area_id)
);

CREATE TABLE IF NOT EXISTS areas_problems (
    area_problem_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    area_id BIGINT REFERENCES areas(area_id) ON DELETE CASCADE NOT NULL,
    problem_id BIGINT REFERENCES problems(problem_id) ON DELETE CASCADE NOT NULL,
    UNIQUE(area_id, problem_id)
);

CREATE TABLE IF NOT EXISTS recipe_problems (
    recipe_problems_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    recipe_id BIGINT REFERENCES recipes(recipe_id) ON DELETE CASCADE NOT NULL,
    problem_id BIGINT REFERENCES problems(problem_id) ON DELETE CASCADE NOT NULL,
    UNIQUE(recipe_id, problem_id)
);

CREATE TABLE IF NOT EXISTS recipe_ingredients (
    recipe_ingredients_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    recipe_id BIGINT REFERENCES recipes(recipe_id) ON DELETE CASCADE NOT NULL,
    ingredient_id BIGINT REFERENCES ingredients(ingredient_id) ON DELETE CASCADE NOT NULL,
    unit_id BIGINT REFERENCES units(unit_id) ON DELETE SET NULL,
    amount DECIMAL,
    UNIQUE(recipe_id, ingredient_id)
);

CREATE TABLE IF NOT EXISTS recipe_tools (
    recipe_tools_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    recipe_id BIGINT REFERENCES recipes(recipe_id) ON DELETE CASCADE NOT NULL,
    tool_id BIGINT REFERENCES tools(tool_id) ON DELETE CASCADE NOT NULL,
    UNIQUE(recipe_id, tool_id)
);

CREATE TABLE IF NOT EXISTS blog_post_categories (
    blog_post_categories_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    blog_post_id BIGINT REFERENCES blog_posts(blog_post_id) ON DELETE CASCADE NOT NULL,
    blog_category_id BIGINT REFERENCES blog_category(blog_category_id) ON DELETE CASCADE NOT NULL,
    UNIQUE(blog_post_id, blog_category_id)
);

CREATE TABLE IF NOT EXISTS recipe_blog_posts (
    recipe_blog_post_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    recipe_id BIGINT REFERENCES recipes(recipe_id) ON DELETE CASCADE NOT NULL,
    blog_post_id BIGINT REFERENCES blog_posts(blog_post_id) ON DELETE CASCADE NOT NULL,
    UNIQUE(recipe_id, blog_post_id)
);
'